{
  "schemaVersion": "1.0",
  "guidelineTitle": "EDI 945 Warehouse Shipping Advice",
  "guidelineVersion": "1.1",
  "transactionCode": "945",
  "x12Version": "004010",
  "definitions": [
    {
      "segmentId": "ISA",
      "segmentName": "Interchange Control Header",
      "usage": "M",
      "maxRepeat": 1,
      "purpose": "To start and identify an interchange of zero or more functional groups and interchange-related control segments",
      "fields": [
        {
          "fieldId": "ISA01",
          "fieldName": "Authorization Information Qualifier",
          "usage": "M",
          "minLength": 2,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code identifying the type of information in the Authorization Information"
        },
        {
          "fieldId": "ISA02",
          "fieldName": "Authorization Information",
          "usage": "M",
          "minLength": 10,
          "maxLength": 10,
          "dataType": "AN",
          "fieldDescription": "Information used for additional identification or authorization of the interchange sender or the data in the interchange"
        },
        {
          "fieldId": "ISA03",
          "fieldName": "Security Information Qualifier",
          "usage": "M",
          "minLength": 2,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code identifying the type of information in the Security Information"
        },
        {
          "fieldId": "ISA04",
          "fieldName": "Security Information",
          "usage": "M",
          "minLength": 10,
          "maxLength": 10,
          "dataType": "AN",
          "fieldDescription": "This is used for identifying the security information about the interchange sender or the data in the interchange"
        },
        {
          "fieldId": "ISA05",
          "fieldName": "Interchange ID Qualifier",
          "usage": "M",
          "minLength": 2,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code indicating the system/method of code structure used to designate the sender or receiver ID element being qualified"
        },
        {
          "fieldId": "ISA06",
          "fieldName": "Interchange Sender ID",
          "usage": "M",
          "minLength": 15,
          "maxLength": 15,
          "dataType": "AN",
          "fieldDescription": "Identification code published by the sender for other parties to use as the receiver ID to route data to them"
        },
        {
          "fieldId": "ISA07",
          "fieldName": "Interchange ID Qualifier",
          "usage": "M",
          "minLength": 2,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code indicating the system/method of code structure used to designate the sender or receiver ID element being qualified"
        },
        {
          "fieldId": "ISA08",
          "fieldName": "Interchange Receiver ID",
          "usage": "M",
          "minLength": 15,
          "maxLength": 15,
          "dataType": "AN",
          "fieldDescription": "Identification code published by the receiver of the data"
        },
        {
          "fieldId": "ISA09",
          "fieldName": "Interchange Date",
          "usage": "M",
          "minLength": 6,
          "maxLength": 6,
          "dataType": "DT",
          "fieldDescription": "Date of the interchange (YYMMDD)"
        },
        {
          "fieldId": "ISA10",
          "fieldName": "Interchange Time",
          "usage": "M",
          "minLength": 4,
          "maxLength": 4,
          "dataType": "TM",
          "fieldDescription": "Time of the interchange"
        },
        {
          "fieldId": "ISA11",
          "fieldName": "Interchange Control Standards Identifier",
          "usage": "M",
          "minLength": 1,
          "maxLength": 1,
          "dataType": "ID",
          "fieldDescription": "Code to identify the agency responsible for the control standard used by the message"
        },
        {
          "fieldId": "ISA12",
          "fieldName": "Interchange Control Version Number Code",
          "usage": "M",
          "minLength": 5,
          "maxLength": 5,
          "dataType": "ID",
          "fieldDescription": "Code specifying the version number of the interchange control segments",
          "allowedValues": [
            {
              "value": "00401",
              "label": "X12 4010 interchange control version"
            }
          ]
        },
        {
          "fieldId": "ISA13",
          "fieldName": "Interchange Control Number",
          "usage": "M",
          "minLength": 9,
          "maxLength": 9,
          "dataType": "N0",
          "fieldDescription": "A control number assigned by the interchange sender"
        },
        {
          "fieldId": "ISA14",
          "fieldName": "Acknowledgment Requested Code",
          "usage": "M",
          "minLength": 1,
          "maxLength": 1,
          "dataType": "ID",
          "fieldDescription": "Code indicating sender's request for an interchange acknowledgment"
        },
        {
          "fieldId": "ISA15",
          "fieldName": "Interchange Usage Indicator Code",
          "usage": "M",
          "minLength": 1,
          "maxLength": 1,
          "dataType": "ID",
          "fieldDescription": "Code indicating whether data enclosed by this interchange envelope is test, production or information"
        },
        {
          "fieldId": "ISA16",
          "fieldName": "Component Data Element Separator",
          "usage": "M",
          "minLength": 1,
          "maxLength": 1,
          "dataType": "-",
          "fieldDescription": "The component data element separator is a delimiter and not a data element"
        }
      ]
    },
    {
      "segmentId": "GS",
      "segmentName": "Functional Group Header",
      "usage": "M",
      "maxRepeat": 1,
      "purpose": "To indicate the beginning of a functional group and to provide control information",
      "fields": [
        {
          "fieldId": "GS01",
          "fieldName": "Functional Identifier Code",
          "usage": "M",
          "minLength": 2,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code identifying a group of application related transaction sets"
        },
        {
          "fieldId": "GS02",
          "fieldName": "Application Sender's Code",
          "usage": "M",
          "minLength": 2,
          "maxLength": 15,
          "dataType": "AN",
          "fieldDescription": "Code identifying party sending transmission"
        },
        {
          "fieldId": "GS03",
          "fieldName": "Application Receiver's Code",
          "usage": "M",
          "minLength": 2,
          "maxLength": 15,
          "dataType": "AN",
          "fieldDescription": "Code identifying party receiving transmission"
        },
        {
          "fieldId": "GS04",
          "fieldName": "Date",
          "usage": "M",
          "minLength": 8,
          "maxLength": 8,
          "dataType": "DT",
          "fieldDescription": "Date expressed as CCYYMMDD"
        },
        {
          "fieldId": "GS05",
          "fieldName": "Time",
          "usage": "M",
          "minLength": 4,
          "maxLength": 8,
          "dataType": "TM",
          "fieldDescription": "Time expressed in 24-hour clock time"
        },
        {
          "fieldId": "GS06",
          "fieldName": "Group Control Number",
          "usage": "M",
          "minLength": 1,
          "maxLength": 9,
          "dataType": "N0",
          "fieldDescription": "Assigned number originated and maintained by the sender"
        },
        {
          "fieldId": "GS07",
          "fieldName": "Responsible Agency Code",
          "usage": "M",
          "minLength": 1,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code identifying the issuer of the standard"
        },
        {
          "fieldId": "GS08",
          "fieldName": "Version / Release / Industry Identifier Code",
          "usage": "M",
          "minLength": 1,
          "maxLength": 12,
          "dataType": "AN",
          "fieldDescription": "Code indicating the version, release, and industry identifier of the EDI Standard",
          "allowedValues": [
            {
              "value": "004010",
              "label": "X12 4010 version/release identifier"
            }
          ]
        }
      ]
    },
    {
      "segmentId": "ST",
      "segmentName": "Transaction Set Header",
      "usage": "M",
      "maxRepeat": 1,
      "purpose": "To indicate the start of a transaction set and to assign a control number",
      "fields": [
        {
          "fieldId": "ST01",
          "fieldName": "Transaction Set Identifier Code",
          "usage": "M",
          "minLength": 3,
          "maxLength": 3,
          "dataType": "ID",
          "fieldDescription": "Code identifying a Transaction Set"
        },
        {
          "fieldId": "ST02",
          "fieldName": "Transaction Set Control Number",
          "usage": "M",
          "minLength": 4,
          "maxLength": 9,
          "dataType": "AN",
          "fieldDescription": "Identifying control number that must be unique within the transaction set functional group"
        }
      ]
    },
    {
      "segmentId": "W06",
      "segmentName": "Warehouse Shipping Order Identification",
      "usage": "M",
      "maxRepeat": 1,
      "purpose": "To identify the warehouse shipping order being transmitted. W06-02 (depositorOrderNumber) is used to look up the matching outbound order. W06-04 (shipmentIdentificationNumber) is used as the BOL.",
      "fields": [
        {
          "fieldId": "W0601",
          "fieldName": "Reporting Code",
          "usage": "M",
          "minLength": 1,
          "maxLength": 1,
          "dataType": "ID",
          "fieldDescription": "Code indicating the status of the warehouse transaction",
          "allowedValues": [
            {
              "value": "F",
              "label": "Final (complete shipment confirmation)"
            },
            {
              "value": "J",
              "label": "Journal/Initial (preliminary notification)"
            }
          ]
        },
        {
          "fieldId": "W0602",
          "fieldName": "Depositor Order Number",
          "usage": "M",
          "minLength": 1,
          "maxLength": 22,
          "dataType": "AN",
          "fieldDescription": "Number assigned by the depositor to identify the order"
        },
        {
          "fieldId": "W0603",
          "fieldName": "Date",
          "usage": "M",
          "minLength": 8,
          "maxLength": 8,
          "dataType": "DT",
          "fieldDescription": "Date expressed as CCYYMMDD"
        },
        {
          "fieldId": "W0604",
          "fieldName": "Shipment Identification Number",
          "usage": "O",
          "minLength": 1,
          "maxLength": 30,
          "dataType": "AN",
          "fieldDescription": "Identification number assigned to the shipment (used as BOL reference)"
        }
      ],
      "syntaxRules": 1
    },
    {
      "segmentId": "N1",
      "segmentName": "Party Identification Loop",
      "usage": "O",
      "maxRepeat": 10,
      "isLoopStart": true,
      "purpose": "Loop containing party identification information",
      "fields": [],
      "nestedSegments": [
        {
          "segmentId": "N1",
          "segmentName": "Party Identification",
          "usage": "M",
          "maxRepeat": 1,
          "purpose": "To identify a party by type of organization, name, and code",
          "fields": [
            {
              "fieldId": "N101",
              "fieldName": "Entity Identifier Code",
              "usage": "M",
              "minLength": 2,
              "maxLength": 3,
              "dataType": "ID",
              "fieldDescription": "Code identifying an organizational entity, a physical location, property or an individual",
              "allowedValues": [
                {
                  "value": "DE",
                  "label": "Destination/Depositor"
                },
                {
                  "value": "ST",
                  "label": "Ship To"
                },
                {
                  "value": "WH",
                  "label": "Warehouse"
                },
                {
                  "value": "SH",
                  "label": "Shipper"
                },
                {
                  "value": "SF",
                  "label": "Ship From"
                },
                {
                  "value": "CA",
                  "label": "Carrier"
                }
              ]
            },
            {
              "fieldId": "N102",
              "fieldName": "Name",
              "usage": "M",
              "minLength": 1,
              "maxLength": 60,
              "dataType": "AN",
              "fieldDescription": "Free-form name"
            },
            {
              "fieldId": "N103",
              "fieldName": "Identification Code Qualifier",
              "usage": "O",
              "minLength": 1,
              "maxLength": 2,
              "dataType": "ID",
              "fieldDescription": "Code designating the system/method of code structure used for Identification Code",
              "allowedValues": [
                {
                  "value": "ZZ",
                  "label": "Mutually Defined"
                },
                {
                  "value": "91",
                  "label": "Assigned by Seller or Seller's Agent"
                },
                {
                  "value": "93",
                  "label": "Code assigned by ultimate destination"
                }
              ]
            },
            {
              "fieldId": "N104",
              "fieldName": "Identification Code",
              "usage": "O",
              "minLength": 2,
              "maxLength": 80,
              "dataType": "AN",
              "fieldDescription": "Code identifying a party or other code"
            }
          ],
          "syntaxRules": 2
        },
        {
          "segmentId": "N3",
          "segmentName": "Party Location",
          "usage": "O",
          "maxRepeat": 1,
          "purpose": "To specify the location of the named party",
          "fields": [
            {
              "fieldId": "N301",
              "fieldName": "Address Information",
              "usage": "M",
              "minLength": 1,
              "maxLength": 55,
              "dataType": "AN",
              "fieldDescription": "Address information"
            },
            {
              "fieldId": "N302",
              "fieldName": "Address Information",
              "usage": "O",
              "minLength": 1,
              "maxLength": 55,
              "dataType": "AN",
              "fieldDescription": "Address information (line 2)"
            }
          ]
        },
        {
          "segmentId": "N4",
          "segmentName": "Geographic Location",
          "usage": "O",
          "maxRepeat": 1,
          "purpose": "To specify the geographic place of the named party",
          "fields": [
            {
              "fieldId": "N401",
              "fieldName": "City Name",
              "usage": "M",
              "minLength": 2,
              "maxLength": 30,
              "dataType": "AN",
              "fieldDescription": "Free-form text for city name"
            },
            {
              "fieldId": "N402",
              "fieldName": "State or Province Code",
              "usage": "M",
              "minLength": 2,
              "maxLength": 2,
              "dataType": "ID",
              "fieldDescription": "State or province code"
            },
            {
              "fieldId": "N403",
              "fieldName": "Postal Code",
              "usage": "O",
              "minLength": 3,
              "maxLength": 15,
              "dataType": "ID",
              "fieldDescription": "Postal zone code"
            },
            {
              "fieldId": "N404",
              "fieldName": "Country Code",
              "usage": "O",
              "minLength": 2,
              "maxLength": 3,
              "dataType": "ID",
              "fieldDescription": "Code identifying the country"
            }
          ],
          "syntaxRules": 1
        }
      ]
    },
    {
      "segmentId": "N9",
      "segmentName": "Extended Reference Information",
      "usage": "O",
      "maxRepeat": 200,
      "purpose": "To transmit identifying information as specified by the Reference Identification Qualifier. Multiple N9 segments may appear at header level with various qualifiers.",
      "fields": [
        {
          "fieldId": "N901",
          "fieldName": "Reference Identification Qualifier",
          "usage": "M",
          "minLength": 2,
          "maxLength": 3,
          "dataType": "ID",
          "fieldDescription": "Code qualifying the Reference Identification",
          "allowedValues": [
            {
              "value": "TN",
              "label": "Transaction Reference Number"
            },
            {
              "value": "PO",
              "label": "Purchase Order Number"
            },
            {
              "value": "IA",
              "label": "Internal Vendor Number"
            },
            {
              "value": "OQ",
              "label": "Order Number"
            },
            {
              "value": "BM",
              "label": "Bill of Lading Number"
            },
            {
              "value": "CR",
              "label": "Customer Reference"
            },
            {
              "value": "VR",
              "label": "Vendor Reference"
            },
            {
              "value": "AS",
              "label": "Alias"
            }
          ]
        },
        {
          "fieldId": "N902",
          "fieldName": "Reference Identification",
          "usage": "M",
          "minLength": 1,
          "maxLength": 30,
          "dataType": "AN",
          "fieldDescription": "Reference information as defined for a particular Transaction Set"
        }
      ],
      "syntaxRules": 2
    },
    {
      "segmentId": "G62",
      "segmentName": "Date/Time Reference",
      "usage": "O",
      "maxRepeat": 10,
      "purpose": "To specify pertinent dates and times at header level",
      "fields": [
        {
          "fieldId": "G6201",
          "fieldName": "Date Qualifier",
          "usage": "M",
          "minLength": 2,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code specifying type of date",
          "allowedValues": [
            {
              "value": "02",
              "label": "Delivery Requested on This Date"
            },
            {
              "value": "04",
              "label": "First Pickup Date"
            },
            {
              "value": "10",
              "label": "Requested Ship Date/Pick-up Date"
            },
            {
              "value": "11",
              "label": "Shipped on This Date"
            },
            {
              "value": "17",
              "label": "Delivery Appointment Date"
            },
            {
              "value": "70",
              "label": "Scheduled Delivery Date"
            }
          ]
        },
        {
          "fieldId": "G6202",
          "fieldName": "Date",
          "usage": "M",
          "minLength": 8,
          "maxLength": 8,
          "dataType": "DT",
          "fieldDescription": "Date expressed as CCYYMMDD"
        }
      ],
      "syntaxRules": 3
    },
    {
      "segmentId": "W27",
      "segmentName": "Carrier Detail - Warehouse",
      "usage": "O",
      "maxRepeat": 1,
      "purpose": "To specify the carrier and equipment associated with a warehouse shipment",
      "fields": [
        {
          "fieldId": "W2701",
          "fieldName": "Transportation Method/Type Code",
          "usage": "M",
          "minLength": 1,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code specifying the method or type of transportation",
          "allowedValues": [
            {
              "value": "M",
              "label": "Motor (Common Carrier)"
            },
            {
              "value": "ZZ",
              "label": "Mutually defined"
            }
          ]
        },
        {
          "fieldId": "W2702",
          "fieldName": "Standard Carrier Alpha Code",
          "usage": "O",
          "minLength": 2,
          "maxLength": 4,
          "dataType": "ID",
          "fieldDescription": "Standard Carrier Alpha Code (SCAC)"
        },
        {
          "fieldId": "W2703",
          "fieldName": "Routing",
          "usage": "O",
          "minLength": 1,
          "maxLength": 35,
          "dataType": "AN",
          "fieldDescription": "Free-form description of the routing or carrier name"
        },
        {
          "fieldId": "W2704",
          "fieldName": "Shipment Method of Payment",
          "usage": "O",
          "minLength": 1,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code specifying payment type (e.g., TP=Third Party)"
        }
      ],
      "syntaxRules": 1
    },
    {
      "segmentId": "W10",
      "segmentName": "Warehouse Additional Carrier Information",
      "usage": "O",
      "maxRepeat": 1,
      "purpose": "To specify warehouse in-transit information such as unit load count",
      "fields": [
        {
          "fieldId": "W1001",
          "fieldName": "Unit Load Option Code",
          "usage": "O",
          "minLength": 2,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code describing the unit load"
        },
        {
          "fieldId": "W1002",
          "fieldName": "Quantity of Pallets Shipped",
          "usage": "O",
          "minLength": 1,
          "maxLength": 3,
          "dataType": "N0",
          "fieldDescription": "Number of pallets shipped"
        }
      ]
    },
    {
      "segmentId": "LX",
      "segmentName": "Line Item Loop",
      "usage": "M",
      "maxRepeat": 999,
      "isLoopStart": true,
      "purpose": "Loop containing line item details. Each LX loop represents a pallet/carton grouping with MAN (SSCC-18) and one or more W12 items.",
      "fields": [],
      "nestedSegments": [
        {
          "segmentId": "LX",
          "segmentName": "Transaction Set Line Number",
          "usage": "M",
          "maxRepeat": 1,
          "purpose": "To reference a line number in a transaction set",
          "fields": [
            {
              "fieldId": "LX01",
              "fieldName": "Assigned Number",
              "usage": "M",
              "minLength": 1,
              "maxLength": 6,
              "dataType": "N0",
              "fieldDescription": "Number assigned for differentiation within a transaction set"
            }
          ]
        },
        {
          "segmentId": "MAN",
          "segmentName": "Marks and Numbers Information",
          "usage": "O",
          "maxRepeat": 1,
          "purpose": "To identify the marks and numbers on the outermost container (pallet-level SSCC-18). Both GM and AA qualifiers are normalized to AA by the parser.",
          "fields": [
            {
              "fieldId": "MAN01",
              "fieldName": "Marks and Numbers Qualifier",
              "usage": "M",
              "minLength": 1,
              "maxLength": 2,
              "dataType": "ID",
              "fieldDescription": "Code identifying the type of marks and numbers",
              "allowedValues": [
                {
                  "value": "AA",
                  "label": "EAN.UCC Serial Shipping Container Code (SSCC)"
                },
                {
                  "value": "GM",
                  "label": "SSCC-18 and Application Identifier (normalized to AA by parser)"
                }
              ]
            },
            {
              "fieldId": "MAN02",
              "fieldName": "Marks and Numbers",
              "usage": "M",
              "minLength": 1,
              "maxLength": 48,
              "dataType": "AN",
              "fieldDescription": "Marks and numbers used to identify a shipment (pallet-level SSCC-18 barcode)"
            }
          ]
        },
        {
          "segmentId": "W12",
          "segmentName": "Warehouse Item Detail Loop",
          "usage": "M",
          "maxRepeat": 999,
          "isLoopStart": true,
          "purpose": "Loop containing warehouse item detail. Each W12 may be followed by G69 (description), N9*LT (lot number), N9*LV (case-level SSCC-18), and G62*36 (expiration date).",
          "fields": [],
          "nestedSegments": [
            {
              "segmentId": "W12",
              "segmentName": "Warehouse Item Detail",
              "usage": "M",
              "maxRepeat": 1,
              "purpose": "To specify warehouse item detail for a shipping advice",
              "fields": [
                {
                  "fieldId": "W1201",
                  "fieldName": "Shipment/Order Status Code",
                  "usage": "M",
                  "minLength": 2,
                  "maxLength": 2,
                  "dataType": "ID",
                  "fieldDescription": "Code indicating the status of the shipment line item. Parsed from element [0]. Only CC items are processed for shipment updates.",
                  "allowedValues": [
                    {
                      "value": "CC",
                      "label": "Shipment Complete"
                    },
                    {
                      "value": "CP",
                      "label": "Partial Shipment"
                    }
                  ]
                },
                {
                  "fieldId": "W1202",
                  "fieldName": "Quantity Ordered",
                  "usage": "M",
                  "minLength": 1,
                  "maxLength": 7,
                  "dataType": "R",
                  "fieldDescription": "Quantity originally ordered. Parsed from element [1] as the primary quantity."
                },
                {
                  "fieldId": "W1203",
                  "fieldName": "Number of Units Shipped",
                  "usage": "M",
                  "minLength": 1,
                  "maxLength": 7,
                  "dataType": "R",
                  "fieldDescription": "Quantity actually shipped. Element [2]."
                },
                {
                  "fieldId": "W1204",
                  "fieldName": "Quantity Difference",
                  "usage": "M",
                  "minLength": 1,
                  "maxLength": 7,
                  "dataType": "R",
                  "fieldDescription": "Difference between quantity ordered and quantity shipped. Element [3]."
                },
                {
                  "fieldId": "W1205",
                  "fieldName": "Unit or Basis for Measurement Code",
                  "usage": "M",
                  "minLength": 2,
                  "maxLength": 2,
                  "dataType": "ID",
                  "fieldDescription": "Code specifying the units of measurement. Element [4].",
                  "allowedValues": [
                    {
                      "value": "EA",
                      "label": "Each"
                    },
                    {
                      "value": "CA",
                      "label": "Case"
                    },
                    {
                      "value": "CT",
                      "label": "Carton"
                    },
                    {
                      "value": "PL",
                      "label": "Pallet/Unit Load"
                    },
                    {
                      "value": "LB",
                      "label": "Pound"
                    },
                    {
                      "value": "BG",
                      "label": "Bag"
                    },
                    {
                      "value": "BO",
                      "label": "Bottle"
                    },
                    {
                      "value": "RL",
                      "label": "Roll"
                    },
                    {
                      "value": "PA",
                      "label": "Pail"
                    },
                    {
                      "value": "SV",
