{
  "schemaVersion": "1.0",
  "guidelineTitle": "EDI 940 Warehouse Shipping Order",
  "guidelineVersion": "1.0",
  "transactionCode": "940",
  "x12Version": "004010",
  "definitions": [
    {
      "segmentId": "ISA",
      "segmentName": "Interchange Control Header",
      "usage": "M",
      "maxRepeat": 1,
      "purpose": "To start and identify an interchange of zero or more functional groups and interchange-related control segments",
      "fields": [
        {
          "fieldId": "ISA01",
          "fieldName": "Authorization Information Qualifier",
          "usage": "M",
          "minLength": 2,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code identifying the type of information in the Authorization Information"
        },
        {
          "fieldId": "ISA02",
          "fieldName": "Authorization Information",
          "usage": "M",
          "minLength": 10,
          "maxLength": 10,
          "dataType": "AN",
          "fieldDescription": "Information used for additional identification or authorization of the interchange sender or the data in the interchange"
        },
        {
          "fieldId": "ISA03",
          "fieldName": "Security Information Qualifier",
          "usage": "M",
          "minLength": 2,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code identifying the type of information in the Security Information"
        },
        {
          "fieldId": "ISA04",
          "fieldName": "Security Information",
          "usage": "M",
          "minLength": 10,
          "maxLength": 10,
          "dataType": "AN",
          "fieldDescription": "This is used for identifying the security information about the interchange sender or the data in the interchange"
        },
        {
          "fieldId": "ISA05",
          "fieldName": "Interchange ID Qualifier",
          "usage": "M",
          "minLength": 2,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code indicating the system/method of code structure used to designate the sender or receiver ID element being qualified"
        },
        {
          "fieldId": "ISA06",
          "fieldName": "Interchange Sender ID",
          "usage": "M",
          "minLength": 15,
          "maxLength": 15,
          "dataType": "AN",
          "fieldDescription": "Identification code published by the sender for other parties to use as the receiver ID to route data to them"
        },
        {
          "fieldId": "ISA07",
          "fieldName": "Interchange ID Qualifier",
          "usage": "M",
          "minLength": 2,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code indicating the system/method of code structure used to designate the sender or receiver ID element being qualified"
        },
        {
          "fieldId": "ISA08",
          "fieldName": "Interchange Receiver ID",
          "usage": "M",
          "minLength": 15,
          "maxLength": 15,
          "dataType": "AN",
          "fieldDescription": "Identification code published by the receiver of the data"
        },
        {
          "fieldId": "ISA09",
          "fieldName": "Interchange Date",
          "usage": "M",
          "minLength": 6,
          "maxLength": 6,
          "dataType": "DT",
          "fieldDescription": "Date of the interchange (YYMMDD)"
        },
        {
          "fieldId": "ISA10",
          "fieldName": "Interchange Time",
          "usage": "M",
          "minLength": 4,
          "maxLength": 4,
          "dataType": "TM",
          "fieldDescription": "Time of the interchange"
        },
        {
          "fieldId": "ISA11",
          "fieldName": "Interchange Control Standards Identifier",
          "usage": "M",
          "minLength": 1,
          "maxLength": 1,
          "dataType": "ID",
          "fieldDescription": "Code to identify the agency responsible for the control standard used by the message"
        },
        {
          "fieldId": "ISA12",
          "fieldName": "Interchange Control Version Number Code",
          "usage": "M",
          "minLength": 5,
          "maxLength": 5,
          "dataType": "ID",
          "fieldDescription": "Code specifying the version number of the interchange control segments",
          "allowedValues": [
            {
              "value": "00401",
              "label": "X12 4010 interchange control version"
            }
          ]
        },
        {
          "fieldId": "ISA13",
          "fieldName": "Interchange Control Number",
          "usage": "M",
          "minLength": 9,
          "maxLength": 9,
          "dataType": "N0",
          "fieldDescription": "A control number assigned by the interchange sender"
        },
        {
          "fieldId": "ISA14",
          "fieldName": "Acknowledgment Requested Code",
          "usage": "M",
          "minLength": 1,
          "maxLength": 1,
          "dataType": "ID",
          "fieldDescription": "Code indicating sender's request for an interchange acknowledgment"
        },
        {
          "fieldId": "ISA15",
          "fieldName": "Interchange Usage Indicator Code",
          "usage": "M",
          "minLength": 1,
          "maxLength": 1,
          "dataType": "ID",
          "fieldDescription": "Code indicating whether data enclosed by this interchange envelope is test, production or information"
        },
        {
          "fieldId": "ISA16",
          "fieldName": "Component Data Element Separator",
          "usage": "M",
          "minLength": 1,
          "maxLength": 1,
          "dataType": "-",
          "fieldDescription": "The component data element separator is a delimiter and not a data element"
        }
      ]
    },
    {
      "segmentId": "GS",
      "segmentName": "Functional Group Header",
      "usage": "M",
      "maxRepeat": 1,
      "purpose": "To indicate the beginning of a functional group and to provide control information",
      "fields": [
        {
          "fieldId": "GS01",
          "fieldName": "Functional Identifier Code",
          "usage": "M",
          "minLength": 2,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code identifying a group of application related transaction sets"
        },
        {
          "fieldId": "GS02",
          "fieldName": "Application Sender's Code",
          "usage": "M",
          "minLength": 2,
          "maxLength": 15,
          "dataType": "AN",
          "fieldDescription": "Code identifying party sending transmission"
        },
        {
          "fieldId": "GS03",
          "fieldName": "Application Receiver's Code",
          "usage": "M",
          "minLength": 2,
          "maxLength": 15,
          "dataType": "AN",
          "fieldDescription": "Code identifying party receiving transmission"
        },
        {
          "fieldId": "GS04",
          "fieldName": "Date",
          "usage": "M",
          "minLength": 8,
          "maxLength": 8,
          "dataType": "DT",
          "fieldDescription": "Date expressed as CCYYMMDD"
        },
        {
          "fieldId": "GS05",
          "fieldName": "Time",
          "usage": "M",
          "minLength": 4,
          "maxLength": 8,
          "dataType": "TM",
          "fieldDescription": "Time expressed in 24-hour clock time"
        },
        {
          "fieldId": "GS06",
          "fieldName": "Group Control Number",
          "usage": "M",
          "minLength": 1,
          "maxLength": 9,
          "dataType": "N0",
          "fieldDescription": "Assigned number originated and maintained by the sender"
        },
        {
          "fieldId": "GS07",
          "fieldName": "Responsible Agency Code",
          "usage": "M",
          "minLength": 1,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code identifying the issuer of the standard"
        },
        {
          "fieldId": "GS08",
          "fieldName": "Version / Release / Industry Identifier Code",
          "usage": "M",
          "minLength": 1,
          "maxLength": 12,
          "dataType": "AN",
          "fieldDescription": "Code indicating the version, release, and industry identifier of the EDI Standard",
          "allowedValues": [
            {
              "value": "004010",
              "label": "X12 4010 version/release identifier"
            }
          ]
        }
      ]
    },
    {
      "segmentId": "ST",
      "segmentName": "Transaction Set Header",
      "usage": "M",
      "maxRepeat": 1,
      "purpose": "To indicate the start of a transaction set and to assign a control number",
      "fields": [
        {
          "fieldId": "ST01",
          "fieldName": "Transaction Set Identifier Code",
          "usage": "M",
          "minLength": 3,
          "maxLength": 3,
          "dataType": "ID",
          "fieldDescription": "Code identifying a Transaction Set"
        },
        {
          "fieldId": "ST02",
          "fieldName": "Transaction Set Control Number",
          "usage": "M",
          "minLength": 4,
          "maxLength": 9,
          "dataType": "AN",
          "fieldDescription": "Identifying control number that must be unique within the transaction set functional group"
        }
      ]
    },
    {
      "segmentId": "W05",
      "segmentName": "Shipping Order Identification",
      "usage": "M",
      "maxRepeat": 1,
      "purpose": "To identify the shipping order being transmitted",
      "fields": [
        {
          "fieldId": "W0501",
          "fieldName": "Order Status Code",
          "usage": "M",
          "minLength": 1,
          "maxLength": 1,
          "dataType": "ID",
          "fieldDescription": "Code indicating the status of the warehouse shipping order",
          "allowedValues": [
            {
              "value": "N",
              "label": "Original"
            },
            {
              "value": "R",
              "label": "Change"
            },
            {
              "value": "C",
              "label": "Confirmation"
            },
            {
              "value": "D",
              "label": "Delete"
            }
          ]
        },
        {
          "fieldId": "W0502",
          "fieldName": "Depositor Order Number",
          "usage": "M",
          "minLength": 1,
          "maxLength": 22,
          "dataType": "AN",
          "fieldDescription": "Number assigned by the depositor to identify the order"
        },
        {
          "fieldId": "W0503",
          "fieldName": "Purchase Order Number",
          "usage": "O",
          "minLength": 1,
          "maxLength": 22,
          "dataType": "AN",
          "fieldDescription": "Identifying number for Purchase Order"
        }
      ],
      "syntaxRules": 1
    },
    {
      "segmentId": "N1",
      "segmentName": "Party Identification Loop",
      "usage": "M",
      "maxRepeat": 10,
      "isLoopStart": true,
      "purpose": "Loop containing party identification information. Repeats for each party (e.g. SH, SF, ST, WH).",
      "fields": [],
      "nestedSegments": [
        {
          "segmentId": "N1",
          "segmentName": "Party Identification",
          "usage": "M",
          "maxRepeat": 1,
          "purpose": "To identify a party by type of organization, name, and code",
          "fields": [
            {
              "fieldId": "N101",
              "fieldName": "Entity Identifier Code",
              "usage": "M",
              "minLength": 2,
              "maxLength": 3,
              "dataType": "ID",
              "fieldDescription": "Code identifying an organizational entity, a physical location, property or an individual",
              "allowedValues": [
                {
                  "value": "SH",
                  "label": "Shipper"
                },
                {
                  "value": "SF",
                  "label": "Ship From"
                },
                {
                  "value": "ST",
                  "label": "Ship To"
                },
                {
                  "value": "WH",
                  "label": "Warehouse"
                }
              ]
            },
            {
              "fieldId": "N102",
              "fieldName": "Name",
              "usage": "M",
              "minLength": 1,
              "maxLength": 60,
              "dataType": "AN",
              "fieldDescription": "Free-form name"
            },
            {
              "fieldId": "N103",
              "fieldName": "Identification Code Qualifier",
              "usage": "O",
              "minLength": 1,
              "maxLength": 2,
              "dataType": "ID",
              "fieldDescription": "Code designating the system/method of code structure used for Identification Code",
              "allowedValues": [
                {
                  "value": "ZZ",
                  "label": "Mutually Defined"
                },
                {
                  "value": "93",
                  "label": "Code assigned by the organization that is the ultimate destination of the transaction set"
                }
              ]
            },
            {
              "fieldId": "N104",
              "fieldName": "Identification Code",
              "usage": "O",
              "minLength": 2,
              "maxLength": 80,
              "dataType": "AN",
              "fieldDescription": "Code identifying a party or other code"
            }
          ],
          "syntaxRules": 2
        },
        {
          "segmentId": "N3",
          "segmentName": "Party Location",
          "usage": "O",
          "maxRepeat": 1,
          "purpose": "To specify the location of the named party",
          "fields": [
            {
              "fieldId": "N301",
              "fieldName": "Address Information",
              "usage": "M",
              "minLength": 1,
              "maxLength": 55,
              "dataType": "AN",
              "fieldDescription": "Address information"
            },
            {
              "fieldId": "N302",
              "fieldName": "Address Information",
              "usage": "O",
              "minLength": 1,
              "maxLength": 55,
              "dataType": "AN",
              "fieldDescription": "Address information (line 2)"
            }
          ]
        },
        {
          "segmentId": "N4",
          "segmentName": "Geographic Location",
          "usage": "O",
          "maxRepeat": 1,
          "purpose": "To specify the geographic place of the named party",
          "fields": [
            {
              "fieldId": "N401",
              "fieldName": "City Name",
              "usage": "M",
              "minLength": 2,
              "maxLength": 30,
              "dataType": "AN",
              "fieldDescription": "Free-form text for city name"
            },
            {
              "fieldId": "N402",
              "fieldName": "State or Province Code",
              "usage": "M",
              "minLength": 2,
              "maxLength": 2,
              "dataType": "ID",
              "fieldDescription": "State or province code"
            },
            {
              "fieldId": "N403",
              "fieldName": "Postal Code",
              "usage": "M",
              "minLength": 3,
              "maxLength": 15,
              "dataType": "ID",
              "fieldDescription": "Postal zone code"
            },
            {
              "fieldId": "N404",
              "fieldName": "Country Code",
              "usage": "O",
              "minLength": 2,
              "maxLength": 3,
              "dataType": "ID",
              "fieldDescription": "Code identifying the country"
            }
          ],
          "syntaxRules": 1
        },
        {
          "segmentId": "G61",
          "segmentName": "Contact",
          "usage": "O",
          "maxRepeat": 3,
          "purpose": "To identify a person or office to whom communication should be directed",
          "fields": [
            {
              "fieldId": "G6101",
              "fieldName": "Contact Function Code",
              "usage": "M",
              "minLength": 2,
              "maxLength": 2,
              "dataType": "ID",
              "fieldDescription": "Code identifying the major duty or responsibility of the person or group named",
              "allowedValues": [
                {
                  "value": "CN",
                  "label": "General Contact"
                }
              ]
            },
            {
              "fieldId": "G6102",
              "fieldName": "Name",
              "usage": "M",
              "minLength": 1,
              "maxLength": 60,
              "dataType": "AN",
              "fieldDescription": "Free-form name"
            },
            {
              "fieldId": "G6103",
              "fieldName": "Communication Number Qualifier",
              "usage": "C",
              "minLength": 2,
              "maxLength": 2,
              "dataType": "ID",
              "fieldDescription": "Code identifying the type of communication number",
              "allowedValues": [
                {
                  "value": "TE",
                  "label": "Telephone"
                },
                {
                  "value": "EM",
                  "label": "Electronic Mail"
                }
              ]
            },
            {
              "fieldId": "G6104",
              "fieldName": "Communication Number",
              "usage": "C",
              "minLength": 1,
              "maxLength": 80,
              "dataType": "AN",
              "fieldDescription": "Complete communications number including country or area code when applicable"
            }
          ],
          "syntaxRules": 1
        }
      ]
    },
    {
      "segmentId": "N9",
      "segmentName": "Extended Reference Information",
      "usage": "O",
      "maxRepeat": 200,
      "purpose": "To transmit identifying information as specified by the Reference Identification Qualifier. Multiple N9 segments are generated at header level for transaction reference, shipment identifiers, order qualifiers, and mapped order reference numbers.",
      "fields": [
        {
          "fieldId": "N901",
          "fieldName": "Reference Identification Qualifier",
          "usage": "M",
          "minLength": 2,
          "maxLength": 3,
          "dataType": "ID",
          "fieldDescription": "Code qualifying the Reference Identification",
          "allowedValues": [
            {
              "value": "TN",
              "label": "Transaction Reference Number"
            },
            {
              "value": "SI",
              "label": "Shipment Identifier"
            },
            {
              "value": "QN",
              "label": "Stop Sequence Number"
            },
            {
              "value": "OQ",
              "label": "Order Number"
            },
            {
              "value": "BM",
              "label": "Bill of Lading Number"
            },
            {
              "value": "MB",
              "label": "Master Bill of Lading"
            },
            {
              "value": "P8",
              "label": "Pickup Reference Number"
            },
            {
              "value": "PO",
              "label": "Purchase Order Number"
            },
            {
              "value": "SO",
              "label": "Shipper's Order (Invoice Number)"
            },
            {
              "value": "DO",
              "label": "Delivery Order Number"
            },
            {
              "value": "IA",
              "label": "Internal Vendor Number"
            },
            {
              "value": "DP",
              "label": "Department Number"
            },
            {
              "value": "AR",
              "label": "Arrival Code"
            },
            {
              "value": "PD",
              "label": "Promotion/Deal Number"
            },
            {
              "value": "PRT",
              "label": "Product Type"
            },
            {
              "value": "SN",
              "label": "Seal Number"
            },
            {
              "value": "LT",
              "label": "Lot Number"
            },
            {
              "value": "XY",
              "label": "Other Unlisted Type of Reference Number"
            }
          ]
        },
        {
          "fieldId": "N902",
          "fieldName": "Reference Identification",
          "usage": "M",
          "minLength": 1,
          "maxLength": 30,
          "dataType": "AN",
          "fieldDescription": "Reference information as defined for a particular Transaction Set"
        }
      ],
      "syntaxRules": 2
    },
    {
      "segmentId": "G62",
      "segmentName": "Date/Time Reference",
      "usage": "M",
      "maxRepeat": 10,
      "purpose": "To specify pertinent dates and times",
      "fields": [
        {
          "fieldId": "G6201",
          "fieldName": "Date Qualifier",
          "usage": "M",
          "minLength": 2,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code specifying type of date",
          "allowedValues": [
            {
              "value": "10",
              "label": "Requested Ship Date/Pick-up Date"
            },
            {
              "value": "02",
              "label": "Delivery Requested on This Date"
            }
          ]
        },
        {
          "fieldId": "G6202",
          "fieldName": "Date",
          "usage": "M",
          "minLength": 8,
          "maxLength": 8,
          "dataType": "DT",
          "fieldDescription": "Date expressed as CCYYMMDD"
        },
        {
          "fieldId": "G6203",
          "fieldName": "Time Qualifier",
          "usage": "C",
          "minLength": 1,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code specifying type of time"
        },
        {
          "fieldId": "G6204",
          "fieldName": "Time",
          "usage": "C",
          "minLength": 4,
          "maxLength": 8,
          "dataType": "TM",
          "fieldDescription": "Time expressed in 24-hour clock time"
        }
      ],
      "syntaxRules": 3
    },
    {
      "segmentId": "NTE",
      "segmentName": "Note/Special Instruction",
      "usage": "O",
      "maxRepeat": 20,
      "purpose": "To transmit information in a free-form format. Long notes are split into multiple NTE segments (max 20 segments, 80 chars each, total 1600 chars). First segment uses WHI, continuation segments use ADD.",
      "fields": [
        {
          "fieldId": "NTE01",
          "fieldName": "Note Reference Code",
          "usage": "M",
          "minLength": 3,
          "maxLength": 3,
          "dataType": "ID",
          "fieldDescription": "Code identifying the functional area or purpose for which the note applies. WHI for the first segment, ADD for continuation segments.",
          "allowedValues": [
            {
              "value": "WHI",
              "label": "Warehouse Instruction (first segment)"
            },
            {
              "value": "ADD",
              "label": "Additional Information (continuation segments)"
            }
          ]
        },
        {
          "fieldId": "NTE02",
          "fieldName": "Description",
          "usage": "M",
          "minLength": 1,
          "maxLength": 80,
          "dataType": "AN",
          "fieldDescription": "Free-form warehouse note, max 80 chars per segment. X12 delimiters (*, ~, >) are stripped by sanitization."
        }
      ]
    },
    {
      "segmentId": "W66",
      "segmentName": "Warehouse Carrier Information",
      "usage": "O",
      "maxRepeat": 1,
      "purpose": "To specify carrier and route information for a warehouse shipping order",
      "fields": [
        {
          "fieldId": "W6601",
          "fieldName": "Shipment Method of Payment",
          "usage": "M",
          "minLength": 2,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code identifying payment terms for transportation charges",
          "allowedValues": [
            {
              "value": "CC",
              "label": "Collect"
            },
            {
              "value": "PP",
              "label": "Prepaid"
            },
            {
              "value": "TP",
              "label": "Third Party Pay"
            }
          ]
        },
        {
          "fieldId": "W6602",
          "fieldName": "Transportation Method/Type Code",
          "usage": "O",
          "minLength": 1,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code specifying the method or type of transportation for the shipment"
        },
        {
          "fieldId": "W6603",
          "fieldName": "Pallet Exchange Code",
          "usage": "O",
          "minLength": 1,
          "maxLength": 1,
          "dataType": "ID",
          "fieldDescription": "Code indicating pallet exchange arrangement"
        },
        {
          "fieldId": "W6604",
          "fieldName": "Unit Load Option Code",
          "usage": "O",
          "minLength": 2,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code indicating the type of unit load device"
        },
        {
          "fieldId": "W6605",
          "fieldName": "Routing",
          "usage": "O",
          "minLength": 1,
          "maxLength": 35,
          "dataType": "AN",
          "fieldDescription": "Free-form description of the routing or route of the shipment"
        }
      ],
      "syntaxRules": 1
    },
    {
      "segmentId": "LX",
      "segmentName": "Line Item Loop",
      "usage": "M",
      "maxRepeat": 999,
      "isLoopStart": true,
      "purpose": "Loop containing line item details. One LX loop per order line item.",
      "fields": [],
      "nestedSegments": [
        {
          "segmentId": "LX",
          "segmentName": "Transaction Set Line Number",
          "usage": "M",
          "maxRepeat": 1,
          "purpose": "To reference a line number in a transaction set",
          "fields": [
            {
              "fieldId": "LX01",
              "fieldName": "Assigned Number",
              "usage": "M",
              "minLength": 1,
              "maxLength": 6,
              "dataType": "N0",
              "fieldDescription": "Number assigned for differentiation within a transaction set"
            }
          ]
        },
        {
          "segmentId": "W01",
          "segmentName": "Line Item Detail Loop",
          "usage": "M",
          "maxRepeat": 1,
          "isLoopStart": true,
          "purpose": "Loop containing line item detail",
          "fields": [],
          "nestedSegments": [
            {
              "segmentId": "W01",
              "segmentName": "Line Item Detail",
              "usage": "M",
              "maxRepeat": 1,
              "purpose": "To specify line item detail for a warehouse shipping order. Elements W01-04 through W01-14 are intentionally left empty. The VN qualifier and SKU are placed at positions W01-15 and W01-16.",
              "fields": [
                {
                  "fieldId": "W0101",
                  "fieldName": "Quantity Ordered",
                  "usage": "M",
                  "minLength": 1,
                  "maxLength": 15,
                  "dataType": "R",
                  "fieldDescription": "Quantity ordered"
                },
                {
                  "fieldId": "W0102",
                  "fieldName": "Unit or Basis for Measurement Code",
                  "usage": "M",
                  "minLength": 2,
                  "maxLength": 2,
                  "dataType": "ID",
                  "fieldDescription": "Code specifying the units in which a value is being expressed",
                  "allowedValues": [
                    {
                      "value": "CA",
                      "label": "Case"
                    },
                    {
                      "value": "EA",
                      "label": "Each"
                    },
