                }
              ]
            },
            {
              "fieldId": "N902",
              "fieldName": "Reference Identification",
              "usage": "M",
              "minLength": 1,
              "maxLength": 30,
              "dataType": "AN",
              "fieldDescription": "Reference information as defined for a particular Transaction Set"
            }
          ],
          "syntaxRules": 2
        }
      ]
    },
    {
      "segmentId": "W14",
      "segmentName": "Total Receipt Information",
      "usage": "O",
      "maxRepeat": 1,
      "purpose": "To specify the total receipt information. Note: not currently parsed by the code but may be present in inbound 944 documents.",
      "fields": [
        {
          "fieldId": "W1401",
          "fieldName": "Quantity Received",
          "usage": "M",
          "minLength": 1,
          "maxLength": 7,
          "dataType": "R",
          "fieldDescription": "Total quantity received"
        },
        {
          "fieldId": "W1402",
          "fieldName": "Number of Units Shipped",
          "usage": "O",
          "minLength": 1,
          "maxLength": 10,
          "dataType": "R",
          "fieldDescription": "Total number of units shipped"
