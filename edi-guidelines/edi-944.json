        {
          "fieldId": "W1403",
          "fieldName": "Number of Units Damaged",
          "usage": "O",
          "minLength": 1,
          "maxLength": 9,
          "dataType": "R",
          "fieldDescription": "Total number of units damaged"
        }
      ]
    },
