{
  "schemaVersion": "1.0",
  "guidelineTitle": "EDI 944 Warehouse Stock Transfer Receipt Advice",
  "guidelineVersion": "1.1",
  "transactionCode": "944",
  "x12Version": "004010",
  "definitions": [
    {
      "segmentId": "ISA",
      "segmentName": "Interchange Control Header",
      "usage": "M",
      "maxRepeat": 1,
      "purpose": "To start and identify an interchange of zero or more functional groups and interchange-related control segments",
      "fields": [
        {
          "fieldId": "ISA01",
          "fieldName": "Authorization Information Qualifier",
          "usage": "M",
          "minLength": 2,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code identifying the type of information in the Authorization Information"
        },
        {
          "fieldId": "ISA02",
          "fieldName": "Authorization Information",
          "usage": "M",
          "minLength": 10,
          "maxLength": 10,
          "dataType": "AN",
          "fieldDescription": "Information used for additional identification or authorization of the interchange sender or the data in the interchange"
        },
        {
          "fieldId": "ISA03",
          "fieldName": "Security Information Qualifier",
          "usage": "M",
          "minLength": 2,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code identifying the type of information in the Security Information"
        },
        {
          "fieldId": "ISA04",
          "fieldName": "Security Information",
          "usage": "M",
          "minLength": 10,
          "maxLength": 10,
          "dataType": "AN",
          "fieldDescription": "This is used for identifying the security information about the interchange sender or the data in the interchange"
        },
        {
          "fieldId": "ISA05",
          "fieldName": "Interchange ID Qualifier",
          "usage": "M",
          "minLength": 2,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code indicating the system/method of code structure used to designate the sender or receiver ID element being qualified"
        },
        {
          "fieldId": "ISA06",
          "fieldName": "Interchange Sender ID",
          "usage": "M",
          "minLength": 15,
          "maxLength": 15,
          "dataType": "AN",
          "fieldDescription": "Identification code published by the sender for other parties to use as the receiver ID to route data to them"
        },
        {
          "fieldId": "ISA07",
          "fieldName": "Interchange ID Qualifier",
          "usage": "M",
          "minLength": 2,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code indicating the system/method of code structure used to designate the sender or receiver ID element being qualified"
        },
        {
          "fieldId": "ISA08",
          "fieldName": "Interchange Receiver ID",
          "usage": "M",
          "minLength": 15,
          "maxLength": 15,
          "dataType": "AN",
          "fieldDescription": "Identification code published by the receiver of the data"
        },
        {
          "fieldId": "ISA09",
          "fieldName": "Interchange Date",
          "usage": "M",
          "minLength": 6,
          "maxLength": 6,
          "dataType": "DT",
          "fieldDescription": "Date of the interchange (YYMMDD)"
        },
        {
          "fieldId": "ISA10",
          "fieldName": "Interchange Time",
          "usage": "M",
          "minLength": 4,
          "maxLength": 4,
          "dataType": "TM",
          "fieldDescription": "Time of the interchange"
        },
        {
          "fieldId": "ISA11",
          "fieldName": "Interchange Control Standards Identifier",
          "usage": "M",
          "minLength": 1,
          "maxLength": 1,
          "dataType": "ID",
          "fieldDescription": "Code to identify the agency responsible for the control standard used by the message"
        },
        {
          "fieldId": "ISA12",
          "fieldName": "Interchange Control Version Number Code",
          "usage": "M",
          "minLength": 5,
          "maxLength": 5,
          "dataType": "ID",
          "fieldDescription": "Code specifying the version number of the interchange control segments",
          "allowedValues": [
            {
              "value": "00401",
              "label": "X12 4010 interchange control version"
            }
          ]
        },
        {
          "fieldId": "ISA13",
          "fieldName": "Interchange Control Number",
          "usage": "M",
          "minLength": 9,
          "maxLength": 9,
          "dataType": "N0",
          "fieldDescription": "A control number assigned by the interchange sender"
        },
        {
          "fieldId": "ISA14",
          "fieldName": "Acknowledgment Requested Code",
          "usage": "M",
          "minLength": 1,
          "maxLength": 1,
          "dataType": "ID",
          "fieldDescription": "Code indicating sender's request for an interchange acknowledgment"
        },
        {
          "fieldId": "ISA15",
          "fieldName": "Interchange Usage Indicator Code",
          "usage": "M",
          "minLength": 1,
          "maxLength": 1,
          "dataType": "ID",
          "fieldDescription": "Code indicating whether data enclosed by this interchange envelope is test, production or information"
        },
        {
          "fieldId": "ISA16",
          "fieldName": "Component Data Element Separator",
          "usage": "M",
          "minLength": 1,
          "maxLength": 1,
          "dataType": "-",
          "fieldDescription": "The component data element separator is a delimiter and not a data element"
        }
      ]
    },
    {
      "segmentId": "GS",
      "segmentName": "Functional Group Header",
      "usage": "M",
      "maxRepeat": 1,
      "purpose": "To indicate the beginning of a functional group and to provide control information",
      "fields": [
        {
          "fieldId": "GS01",
          "fieldName": "Functional Identifier Code",
          "usage": "M",
          "minLength": 2,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code identifying a group of application related transaction sets"
        },
        {
          "fieldId": "GS02",
          "fieldName": "Application Sender's Code",
          "usage": "M",
          "minLength": 2,
          "maxLength": 15,
          "dataType": "AN",
          "fieldDescription": "Code identifying party sending transmission"
        },
        {
          "fieldId": "GS03",
          "fieldName": "Application Receiver's Code",
          "usage": "M",
          "minLength": 2,
          "maxLength": 15,
          "dataType": "AN",
          "fieldDescription": "Code identifying party receiving transmission"
        },
        {
          "fieldId": "GS04",
          "fieldName": "Date",
          "usage": "M",
          "minLength": 8,
          "maxLength": 8,
          "dataType": "DT",
          "fieldDescription": "Date expressed as CCYYMMDD"
        },
        {
          "fieldId": "GS05",
          "fieldName": "Time",
          "usage": "M",
          "minLength": 4,
          "maxLength": 8,
          "dataType": "TM",
          "fieldDescription": "Time expressed in 24-hour clock time"
        },
        {
          "fieldId": "GS06",
          "fieldName": "Group Control Number",
          "usage": "M",
          "minLength": 1,
          "maxLength": 9,
          "dataType": "N0",
          "fieldDescription": "Assigned number originated and maintained by the sender"
        },
        {
          "fieldId": "GS07",
          "fieldName": "Responsible Agency Code",
          "usage": "M",
          "minLength": 1,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code identifying the issuer of the standard"
        },
        {
          "fieldId": "GS08",
          "fieldName": "Version / Release / Industry Identifier Code",
          "usage": "M",
          "minLength": 1,
          "maxLength": 12,
          "dataType": "AN",
          "fieldDescription": "Code indicating the version, release, and industry identifier of the EDI Standard",
          "allowedValues": [
            {
              "value": "004010",
              "label": "X12 4010 version/release identifier"
            }
          ]
        }
      ]
    },
    {
      "segmentId": "ST",
      "segmentName": "Transaction Set Header",
      "usage": "M",
      "maxRepeat": 1,
      "purpose": "To indicate the start of a transaction set and to assign a control number",
      "fields": [
        {
          "fieldId": "ST01",
          "fieldName": "Transaction Set Identifier Code",
          "usage": "M",
          "minLength": 3,
          "maxLength": 3,
          "dataType": "ID",
          "fieldDescription": "Code identifying a Transaction Set"
        },
        {
          "fieldId": "ST02",
          "fieldName": "Transaction Set Control Number",
          "usage": "M",
          "minLength": 4,
          "maxLength": 9,
          "dataType": "AN",
          "fieldDescription": "Identifying control number that must be unique within the transaction set functional group"
        }
      ]
    },
    {
      "segmentId": "W17",
      "segmentName": "Warehouse Receipt Identification",
      "usage": "M",
      "maxRepeat": 1,
      "purpose": "To identify the warehouse receipt being transmitted",
      "fields": [
        {
          "fieldId": "W1701",
          "fieldName": "Reporting Code",
          "usage": "M",
          "minLength": 1,
          "maxLength": 1,
          "dataType": "ID",
          "fieldDescription": "Code indicating the status of the warehouse transaction",
          "allowedValues": [
            {
              "value": "F",
              "label": "Final"
            },
            {
              "value": "J",
              "label": "Original Transaction"
            }
          ]
        },
        {
          "fieldId": "W1702",
          "fieldName": "Date",
          "usage": "M",
          "minLength": 8,
          "maxLength": 8,
          "dataType": "DT",
          "fieldDescription": "Date expressed as CCYYMMDD"
        },
        {
          "fieldId": "W1703",
          "fieldName": "Warehouse Receipt Number",
          "usage": "M",
          "minLength": 1,
          "maxLength": 22,
          "dataType": "AN",
          "fieldDescription": "Number assigned by the warehouse for this receipt"
        },
        {
          "fieldId": "W1704",
          "fieldName": "Depositor Order Number",
          "usage": "M",
          "minLength": 1,
          "maxLength": 22,
          "dataType": "AN",
          "fieldDescription": "Number assigned by the depositor to identify the order. Used by the parser (element [3]) to look up the matching inbound order."
        }
      ],
      "syntaxRules": 2
    },
    {
      "segmentId": "N1",
      "segmentName": "Party Identification Loop",
      "usage": "O",
      "maxRepeat": 10,
      "isLoopStart": true,
      "purpose": "Loop containing party identification information",
      "fields": [],
      "nestedSegments": [
        {
          "segmentId": "N1",
          "segmentName": "Party Identification",
          "usage": "M",
          "maxRepeat": 1,
          "purpose": "To identify a party by type of organization, name, and code",
          "fields": [
            {
              "fieldId": "N101",
              "fieldName": "Entity Identifier Code",
              "usage": "M",
              "minLength": 2,
              "maxLength": 3,
              "dataType": "ID",
              "fieldDescription": "Code identifying an organizational entity, a physical location, property or an individual",
              "allowedValues": [
                {
                  "value": "WH",
                  "label": "Warehouse"
                },
                {
                  "value": "DE",
                  "label": "Depositor"
                },
                {
                  "value": "SH",
                  "label": "Shipper"
                }
              ]
            },
            {
              "fieldId": "N102",
              "fieldName": "Name",
              "usage": "M",
              "minLength": 1,
              "maxLength": 60,
              "dataType": "AN",
              "fieldDescription": "Free-form name"
            },
            {
              "fieldId": "N103",
              "fieldName": "Identification Code Qualifier",
              "usage": "O",
              "minLength": 1,
              "maxLength": 2,
              "dataType": "ID",
              "fieldDescription": "Code designating the system/method of code structure used for Identification Code"
            },
            {
              "fieldId": "N104",
              "fieldName": "Identification Code",
              "usage": "O",
              "minLength": 2,
              "maxLength": 80,
              "dataType": "AN",
              "fieldDescription": "Code identifying a party or other code"
            }
          ],
          "syntaxRules": 2
        },
        {
          "segmentId": "N3",
          "segmentName": "Party Location",
          "usage": "O",
          "maxRepeat": 2,
          "purpose": "To specify the location of the named party",
          "fields": [
            {
              "fieldId": "N301",
              "fieldName": "Address Information",
              "usage": "M",
              "minLength": 1,
              "maxLength": 55,
              "dataType": "AN",
              "fieldDescription": "Address information"
            },
            {
              "fieldId": "N302",
              "fieldName": "Address Information",
              "usage": "O",
              "minLength": 1,
              "maxLength": 55,
              "dataType": "AN",
              "fieldDescription": "Address information (line 2)"
            }
          ]
        },
        {
          "segmentId": "N4",
          "segmentName": "Geographic Location",
          "usage": "O",
          "maxRepeat": 1,
          "purpose": "To specify the geographic place of the named party",
          "fields": [
            {
              "fieldId": "N401",
              "fieldName": "City Name",
              "usage": "M",
              "minLength": 2,
              "maxLength": 30,
              "dataType": "AN",
              "fieldDescription": "Free-form text for city name"
            },
            {
              "fieldId": "N402",
              "fieldName": "State or Province Code",
              "usage": "M",
              "minLength": 2,
              "maxLength": 2,
              "dataType": "ID",
              "fieldDescription": "State or province code"
            },
            {
              "fieldId": "N403",
              "fieldName": "Postal Code",
              "usage": "M",
              "minLength": 3,
              "maxLength": 15,
              "dataType": "ID",
              "fieldDescription": "Postal zone code"
            },
            {
              "fieldId": "N404",
              "fieldName": "Country Code",
              "usage": "O",
              "minLength": 2,
              "maxLength": 3,
              "dataType": "ID",
              "fieldDescription": "Code identifying the country"
            }
          ],
          "syntaxRules": 1
        }
      ]
    },
    {
      "segmentId": "N9",
      "segmentName": "Extended Reference Information",
      "usage": "O",
      "maxRepeat": 200,
      "purpose": "To transmit identifying information as specified by the Reference Identification Qualifier",
      "fields": [
        {
          "fieldId": "N901",
          "fieldName": "Reference Identification Qualifier",
          "usage": "M",
          "minLength": 2,
          "maxLength": 3,
          "dataType": "ID",
          "fieldDescription": "Code qualifying the Reference Identification",
          "allowedValues": [
            {
              "value": "TN",
              "label": "Transaction Reference Number"
            }
          ]
        },
        {
          "fieldId": "N902",
          "fieldName": "Reference Identification",
          "usage": "M",
          "minLength": 1,
          "maxLength": 30,
          "dataType": "AN",
          "fieldDescription": "Reference information as defined for a particular Transaction Set"
        }
      ],
      "syntaxRules": 2
    },
    {
      "segmentId": "G62",
      "segmentName": "Date/Time Reference",
      "usage": "O",
      "maxRepeat": 5,
      "purpose": "To specify pertinent dates and times",
      "fields": [
        {
          "fieldId": "G6201",
          "fieldName": "Date Qualifier",
          "usage": "M",
          "minLength": 2,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code specifying type of date",
          "allowedValues": [
            {
              "value": "BS",
              "label": "Product Receipt Date"
            },
            {
              "value": "11",
              "label": "Report Date"
            }
          ]
        },
        {
          "fieldId": "G6202",
          "fieldName": "Date",
          "usage": "M",
          "minLength": 8,
          "maxLength": 8,
          "dataType": "DT",
          "fieldDescription": "Date expressed as CCYYMMDD"
        }
      ],
      "syntaxRules": 3
    },
    {
      "segmentId": "W07",
      "segmentName": "Item Detail for Stock Receipt Loop",
      "usage": "M",
      "maxRepeat": 999,
      "isLoopStart": true,
      "purpose": "Loop containing item detail for stock receipt. Unlike 940/945, W07 items in 944 are NOT wrapped in LX segments - they appear directly at the transaction level. Each W07 may be followed by N9*LT for lot number.",
      "fields": [],
      "nestedSegments": [
        {
          "segmentId": "W07",
          "segmentName": "Item Detail for Stock Receipt",
          "usage": "M",
          "maxRepeat": 1,
          "purpose": "To specify item detail for a warehouse stock receipt",
          "fields": [
            {
              "fieldId": "W0701",
              "fieldName": "Quantity Received",
              "usage": "M",
              "minLength": 1,
              "maxLength": 7,
              "dataType": "R",
              "fieldDescription": "Quantity of product received. Parsed from element [0]."
            },
            {
              "fieldId": "W0702",
              "fieldName": "Unit or Basis for Measurement Code",
              "usage": "M",
              "minLength": 2,
              "maxLength": 2,
              "dataType": "ID",
              "fieldDescription": "Code specifying the units of measurement. Parsed from element [1].",
              "allowedValues": [
                {
                  "value": "EA",
                  "label": "Each"
                },
                {
                  "value": "CA",
                  "label": "Case"
                },
                {
                  "value": "CT",
                  "label": "Carton"
                },
                {
                  "value": "PL",
                  "label": "Pallet/Unit Load"
                },
                {
                  "value": "LB",
                  "label": "Pound"
                },
                {
                  "value": "BG",
                  "label": "Bag"
                },
                {
                  "value": "BO",
                  "label": "Bottle"
                },
                {
                  "value": "RL",
                  "label": "Roll"
                },
                {
                  "value": "PA",
                  "label": "Pail"
                },
                {
                  "value": "SV",
                  "label": "Skid"
                },
                {
                  "value": "BX",
                  "label": "Box"
                },
                {
                  "value": "DR",
                  "label": "Drum"
                },
                {
                  "value": "KG",
                  "label": "Kilogram"
                },
                {
                  "value": "PC",
                  "label": "Piece"
                },
                {
                  "value": "BD",
                  "label": "Bundle"
                }
              ]
            },
            {
              "fieldId": "W0703",
              "fieldName": "U.P.C. Case Code",
              "usage": "C",
              "minLength": 12,
              "maxLength": 12,
              "dataType": "AN",
              "fieldDescription": "UPC Case Code (GTIN-12). Element [2], skipped by parser."
            },
            {
              "fieldId": "W0704",
              "fieldName": "Product/Service ID Qualifier",
              "usage": "C",
              "minLength": 2,
              "maxLength": 2,
              "dataType": "ID",
              "fieldDescription": "Code identifying the type/source of the descriptive number used in W0705. Parsed from element [3].",
              "allowedValues": [
                {
                  "value": "VN",
                  "label": "Vendor's (Seller's) Item Number"
                },
                {
                  "value": "VA",
                  "label": "Vendor's Part Number"
                },
                {
                  "value": "UP",
                  "label": "U.P.C. Consumer Package Code (1-5-5-1)"
                },
                {
                  "value": "IN",
                  "label": "Buyer's Item Number"
                },
                {
                  "value": "SK",
                  "label": "Stock Keeping Unit (SKU)"
                },
                {
                  "value": "CB",
                  "label": "Buyer's Catalog Number"
                }
              ]
            },
            {
              "fieldId": "W0705",
              "fieldName": "Product/Service ID",
              "usage": "C",
              "minLength": 1,
              "maxLength": 48,
              "dataType": "AN",
              "fieldDescription": "Identifying number for a product or service (SKU). Parsed from element [4]. Required when W0704 is present."
            },
            {
              "fieldId": "W0706",
              "fieldName": "Product/Service ID Qualifier (2nd)",
              "usage": "O",
              "minLength": 2,
              "maxLength": 2,
              "dataType": "ID",
              "fieldDescription": "Code identifying the type/source of a secondary product identifier in W0707. Parsed from element [5].",
              "allowedValues": [
                {
                  "value": "SC",
                  "label": "Seller's Date Code (expiration date)"
                },
                {
                  "value": "UP",
                  "label": "U.P.C. Consumer Package Code"
                },
                {
                  "value": "CB",
                  "label": "Buyer's Catalog Number"
                },
                {
                  "value": "VA",
                  "label": "Vendor's Part Number"
                }
              ]
            },
            {
              "fieldId": "W0707",
              "fieldName": "Product/Service ID (2nd)",
              "usage": "O",
              "minLength": 1,
              "maxLength": 80,
              "dataType": "AN",
              "fieldDescription": "Secondary identifying number. When W0706=SC, this contains the expiration date (CCYYMMDD). Parsed from element [6]."
            },
            {
              "fieldId": "W0708",
              "fieldName": "Warehouse Lot Number",
              "usage": "O",
              "minLength": 1,
              "maxLength": 12,
              "dataType": "AN",
              "fieldDescription": "Warehouse lot/batch tracking number. Parsed from element [7]. Can be overridden by child N9*LT segment (N9*LT takes precedence)."
            }
          ],
          "syntaxRules": 4
        },
        {
          "segmentId": "N9",
          "segmentName": "Extended Reference Information",
          "usage": "O",
          "maxRepeat": 200,
          "purpose": "To transmit identifying information. Follows W07 segment. N9*LT provides lot number and overrides W07-08 if both present.",
