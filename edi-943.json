{
  "schemaVersion": "1.0",
  "guidelineTitle": "EDI 943 Warehouse Stock Transfer Shipment Advice",
  "guidelineVersion": "1.0",
  "transactionCode": "943",
  "definitions": [
    {
      "segmentId": "ISA",
      "segmentName": "Interchange Control Header",
      "usage": "M",
      "maxRepeat": 1,
      "purpose": "To start and identify an interchange of zero or more functional groups and interchange-related control segments",
      "fields": [
        {
          "fieldId": "ISA01",
          "fieldName": "Authorization Information Qualifier",
          "usage": "M",
          "minLength": 2,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code identifying the type of information in the Authorization Information"
        },
        {
          "fieldId": "ISA02",
          "fieldName": "Authorization Information",
          "usage": "M",
          "minLength": 10,
          "maxLength": 10,
          "dataType": "AN",
          "fieldDescription": "Information used for additional identification or authorization of the interchange sender or the data in the interchange"
        },
        {
          "fieldId": "ISA03",
          "fieldName": "Security Information Qualifier",
          "usage": "M",
          "minLength": 2,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code identifying the type of information in the Security Information"
        },
        {
          "fieldId": "ISA04",
          "fieldName": "Security Information",
          "usage": "M",
          "minLength": 10,
          "maxLength": 10,
          "dataType": "AN",
          "fieldDescription": "This is used for identifying the security information about the interchange sender or the data in the interchange"
        },
        {
          "fieldId": "ISA05",
          "fieldName": "Interchange ID Qualifier",
          "usage": "M",
          "minLength": 2,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code indicating the system/method of code structure used to designate the sender or receiver ID element being qualified"
        },
        {
          "fieldId": "ISA06",
          "fieldName": "Interchange Sender ID",
          "usage": "M",
          "minLength": 15,
          "maxLength": 15,
          "dataType": "AN",
          "fieldDescription": "Identification code published by the sender for other parties to use as the receiver ID to route data to them"
        },
        {
          "fieldId": "ISA07",
          "fieldName": "Interchange ID Qualifier",
          "usage": "M",
          "minLength": 2,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code indicating the system/method of code structure used to designate the sender or receiver ID element being qualified"
        },
        {
          "fieldId": "ISA08",
          "fieldName": "Interchange Receiver ID",
          "usage": "M",
          "minLength": 15,
          "maxLength": 15,
          "dataType": "AN",
          "fieldDescription": "Identification code published by the receiver of the data"
        },
        {
          "fieldId": "ISA09",
          "fieldName": "Interchange Date",
          "usage": "M",
          "minLength": 6,
          "maxLength": 6,
          "dataType": "DT",
          "fieldDescription": "Date of the interchange (YYMMDD)"
        },
        {
          "fieldId": "ISA10",
          "fieldName": "Interchange Time",
          "usage": "M",
          "minLength": 4,
          "maxLength": 4,
          "dataType": "TM",
          "fieldDescription": "Time of the interchange"
        },
        {
          "fieldId": "ISA11",
          "fieldName": "Interchange Control Standards Identifier",
          "usage": "M",
          "minLength": 1,
          "maxLength": 1,
          "dataType": "ID",
          "fieldDescription": "Code to identify the agency responsible for the control standard used by the message"
        },
        {
          "fieldId": "ISA12",
          "fieldName": "Interchange Control Version Number Code",
          "usage": "M",
          "minLength": 5,
          "maxLength": 5,
          "dataType": "ID",
          "fieldDescription": "Code specifying the version number of the interchange control segments"
        },
        {
          "fieldId": "ISA13",
          "fieldName": "Interchange Control Number",
          "usage": "M",
          "minLength": 9,
          "maxLength": 9,
          "dataType": "N0",
          "fieldDescription": "A control number assigned by the interchange sender"
        },
        {
          "fieldId": "ISA14",
          "fieldName": "Acknowledgment Requested Code",
          "usage": "M",
          "minLength": 1,
          "maxLength": 1,
          "dataType": "ID",
          "fieldDescription": "Code indicating sender's request for an interchange acknowledgment"
        },
        {
          "fieldId": "ISA15",
          "fieldName": "Interchange Usage Indicator Code",
          "usage": "M",
          "minLength": 1,
          "maxLength": 1,
          "dataType": "ID",
          "fieldDescription": "Code indicating whether data enclosed by this interchange envelope is test, production or information"
        },
        {
          "fieldId": "ISA16",
          "fieldName": "Component Data Element Separator",
          "usage": "M",
          "minLength": 1,
          "maxLength": 1,
          "dataType": "-",
          "fieldDescription": "The component data element separator is a delimiter and not a data element"
        }
      ]
    },
    {
      "segmentId": "GS",
      "segmentName": "Functional Group Header",
      "usage": "M",
      "maxRepeat": 1,
      "purpose": "To indicate the beginning of a functional group and to provide control information",
      "fields": [
        {
          "fieldId": "GS01",
          "fieldName": "Functional Identifier Code",
          "usage": "M",
          "minLength": 2,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code identifying a group of application related transaction sets"
        },
        {
          "fieldId": "GS02",
          "fieldName": "Application Sender's Code",
          "usage": "M",
          "minLength": 2,
          "maxLength": 15,
          "dataType": "AN",
          "fieldDescription": "Code identifying party sending transmission"
        },
        {
          "fieldId": "GS03",
          "fieldName": "Application Receiver's Code",
          "usage": "M",
          "minLength": 2,
          "maxLength": 15,
          "dataType": "AN",
          "fieldDescription": "Code identifying party receiving transmission"
        },
        {
          "fieldId": "GS04",
          "fieldName": "Date",
          "usage": "M",
          "minLength": 8,
          "maxLength": 8,
          "dataType": "DT",
          "fieldDescription": "Date expressed as CCYYMMDD"
        },
        {
          "fieldId": "GS05",
          "fieldName": "Time",
          "usage": "M",
          "minLength": 4,
          "maxLength": 8,
          "dataType": "TM",
          "fieldDescription": "Time expressed in 24-hour clock time"
        },
        {
          "fieldId": "GS06",
          "fieldName": "Group Control Number",
          "usage": "M",
          "minLength": 1,
          "maxLength": 9,
          "dataType": "N0",
          "fieldDescription": "Assigned number originated and maintained by the sender"
        },
        {
          "fieldId": "GS07",
          "fieldName": "Responsible Agency Code",
          "usage": "M",
          "minLength": 1,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code identifying the issuer of the standard"
        },
        {
          "fieldId": "GS08",
          "fieldName": "Version / Release / Industry Identifier Code",
          "usage": "M",
          "minLength": 1,
          "maxLength": 12,
          "dataType": "AN",
          "fieldDescription": "Code indicating the version, release, and industry identifier of the EDI Standard"
        }
      ]
    },
    {
      "segmentId": "ST",
      "segmentName": "Transaction Set Header",
      "usage": "M",
      "maxRepeat": 1,
      "purpose": "To indicate the start of a transaction set and to assign a control number",
      "fields": [
        {
          "fieldId": "ST01",
          "fieldName": "Transaction Set Identifier Code",
          "usage": "M",
          "minLength": 3,
          "maxLength": 3,
          "dataType": "ID",
          "fieldDescription": "Code identifying a Transaction Set"
        },
        {
          "fieldId": "ST02",
          "fieldName": "Transaction Set Control Number",
          "usage": "M",
          "minLength": 4,
          "maxLength": 9,
          "dataType": "AN",
          "fieldDescription": "Identifying control number that must be unique within the transaction set functional group"
        }
      ]
    },
    {
      "segmentId": "W06",
      "segmentName": "Warehouse Shipping Order Identification",
      "usage": "M",
      "maxRepeat": 1,
      "purpose": "To identify the warehouse shipping order being transmitted",
      "fields": [
        {
          "fieldId": "W0601",
          "fieldName": "Reporting Code",
          "usage": "M",
          "minLength": 1,
          "maxLength": 1,
          "dataType": "ID",
          "fieldDescription": "Code indicating the status of the warehouse transaction",
          "allowedValues": [
            {
              "value": "J",
              "label": "Original Transaction"
            }
          ]
        },
        {
          "fieldId": "W0602",
          "fieldName": "Depositor Order Number",
          "usage": "M",
          "minLength": 1,
          "maxLength": 22,
          "dataType": "AN",
          "fieldDescription": "Number assigned by the depositor to identify the order"
        },
        {
          "fieldId": "W0603",
          "fieldName": "Date",
          "usage": "M",
          "minLength": 8,
          "maxLength": 8,
          "dataType": "DT",
          "fieldDescription": "Date expressed as CCYYMMDD"
        },
        {
          "fieldId": "W0604",
          "fieldName": "Shipment Identification Number",
          "usage": "O",
          "minLength": 1,
          "maxLength": 30,
          "dataType": "AN",
          "fieldDescription": "Identification number assigned to the shipment"
        }
      ],
      "syntaxRules": 1
    },
    {
      "segmentId": "N1",
      "segmentName": "Party Identification",
      "usage": "M",
      "maxRepeat": 5,
      "isLoopStart": true,
      "purpose": "To identify a party by type of organization, name, and code. Repeats for each party (e.g. SH, SF, WH).",
      "fields": [
        {
          "fieldId": "N101",
          "fieldName": "Entity Identifier Code",
          "usage": "M",
          "minLength": 2,
          "maxLength": 3,
          "dataType": "ID",
          "fieldDescription": "Code identifying an organizational entity, a physical location, property or an individual",
          "allowedValues": [
            {
              "value": "WH",
              "label": "Warehouse"
            },
            {
              "value": "SF",
              "label": "Ship From"
            },
            {
              "value": "SH",
              "label": "Shipper"
            }
          ]
        },
        {
          "fieldId": "N102",
          "fieldName": "Name",
          "usage": "M",
          "minLength": 1,
          "maxLength": 60,
          "dataType": "AN",
          "fieldDescription": "Free-form name"
        },
        {
          "fieldId": "N103",
          "fieldName": "Identification Code Qualifier",
          "usage": "O",
          "minLength": 1,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code designating the system/method of code structure used for Identification Code"
        },
        {
          "fieldId": "N104",
          "fieldName": "Identification Code",
          "usage": "O",
          "minLength": 2,
          "maxLength": 80,
          "dataType": "AN",
          "fieldDescription": "Code identifying a party or other code"
        }
      ],
      "nestedSegments": [
        {
          "segmentId": "N3",
          "segmentName": "Party Location",
          "usage": "O",
          "maxRepeat": 1,
          "purpose": "To specify the location of the named party",
          "fields": [
            {
              "fieldId": "N301",
              "fieldName": "Address Information",
              "usage": "M",
              "minLength": 1,
              "maxLength": 55,
              "dataType": "AN",
              "fieldDescription": "Address information"
            }
          ]
        },
        {
          "segmentId": "N4",
          "segmentName": "Geographic Location",
          "usage": "O",
          "maxRepeat": 1,
          "purpose": "To specify the geographic place of the named party",
          "fields": [
            {
              "fieldId": "N401",
              "fieldName": "City Name",
              "usage": "M",
              "minLength": 2,
              "maxLength": 30,
              "dataType": "AN",
              "fieldDescription": "Free-form text for city name"
            },
            {
              "fieldId": "N402",
              "fieldName": "State or Province Code",
              "usage": "M",
              "minLength": 2,
              "maxLength": 2,
              "dataType": "ID",
              "fieldDescription": "State or province code"
            },
            {
              "fieldId": "N403",
              "fieldName": "Postal Code",
              "usage": "M",
              "minLength": 3,
              "maxLength": 15,
              "dataType": "ID",
              "fieldDescription": "Postal zone code"
            },
            {
              "fieldId": "N404",
              "fieldName": "Country Code",
              "usage": "O",
              "minLength": 2,
              "maxLength": 3,
              "dataType": "ID",
              "fieldDescription": "Code identifying the country"
            }
          ],
          "syntaxRules": 1
        }
      ]
    },
    {
      "segmentId": "N9",
      "segmentName": "Extended Reference Information",
      "usage": "O",
      "maxRepeat": 1,
      "purpose": "To transmit identifying information as specified by the Reference Identification Qualifier",
      "fields": [
        {
          "fieldId": "N901",
          "fieldName": "Reference Identification Qualifier",
          "usage": "M",
          "minLength": 2,
          "maxLength": 3,
          "dataType": "ID",
          "fieldDescription": "Code qualifying the Reference Identification",
          "allowedValues": [
            {
              "value": "TN",
              "label": "Transaction Reference Number"
            }
          ]
        },
        {
          "fieldId": "N902",
          "fieldName": "Reference Identification",
          "usage": "M",
          "minLength": 1,
          "maxLength": 30,
          "dataType": "AN",
          "fieldDescription": "Reference information as defined for a particular Transaction Set"
        }
      ],
      "syntaxRules": 2
    },
    {
      "segmentId": "G62",
      "segmentName": "Date/Time Reference",
      "usage": "O",
      "maxRepeat": 5,
      "purpose": "To specify pertinent dates and times",
      "fields": [
        {
          "fieldId": "G6201",
          "fieldName": "Date Qualifier",
          "usage": "M",
          "minLength": 2,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code specifying type of date",
          "allowedValues": [
            {
              "value": "11",
              "label": "Shipped on This Date"
            },
            {
              "value": "70",
              "label": "Scheduled Delivery Date"
            }
          ]
        },
        {
          "fieldId": "G6202",
          "fieldName": "Date",
          "usage": "M",
          "minLength": 8,
          "maxLength": 8,
          "dataType": "DT",
          "fieldDescription": "Date expressed as CCYYMMDD"
        }
      ],
      "syntaxRules": 3
    },
    {
      "segmentId": "W27",
      "segmentName": "Carrier Detail - Warehouse",
      "usage": "O",
      "maxRepeat": 1,
      "purpose": "To specify the carrier and equipment associated with a warehouse shipment",
      "fields": [
        {
          "fieldId": "W2701",
          "fieldName": "Transportation Method/Type Code",
          "usage": "M",
          "minLength": 1,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code specifying the method or type of transportation",
          "allowedValues": [
            {
              "value": "ZZ",
              "label": "Mutually defined"
            }
          ]
        },
        {
          "fieldId": "W2702",
          "fieldName": "Standard Carrier Alpha Code",
          "usage": "O",
          "minLength": 2,
          "maxLength": 4,
          "dataType": "ID",
          "fieldDescription": "Standard Carrier Alpha Code"
        },
        {
          "fieldId": "W2703",
          "fieldName": "Routing",
          "usage": "O",
          "minLength": 1,
          "maxLength": 35,
          "dataType": "AN",
          "fieldDescription": "Free-form description of the routing or route code"
        },
        {
          "fieldId": "W2704",
          "fieldName": "Equipment Number",
          "usage": "O",
          "minLength": 1,
          "maxLength": 10,
          "dataType": "AN",
          "fieldDescription": "Serial part of equipment unit's identifying number"
        }
      ],
      "syntaxRules": 1
    },
    {
      "segmentId": "W04",
      "segmentName": "Item Detail Total",
      "usage": "M",
      "maxRepeat": 999,
      "isLoopStart": true,
      "purpose": "To specify total quantity and item identification. Repeats for each line item.",
      "fields": [
        {
          "fieldId": "W0401",
          "fieldName": "Number of Units Shipped",
          "usage": "M",
          "minLength": 1,
          "maxLength": 10,
          "dataType": "R",
          "fieldDescription": "Numeric value of units shipped in manufacturer's shipping units"
        },
        {
          "fieldId": "W0402",
          "fieldName": "Unit or Basis for Measurement Code",
          "usage": "M",
          "minLength": 2,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code specifying the units",
          "allowedValues": [
            {
              "value": "CA",
              "label": "Case"
            },
            {
              "value": "EA",
              "label": "Each"
            }
          ]
        },
        {
          "fieldId": "W0404",
          "fieldName": "Product/Service ID Qualifier",
          "usage": "M",
          "minLength": 2,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code identifying the type/source of the descriptive number. W0403 is reserved/empty.",
          "allowedValues": [
            {
              "value": "VN",
              "label": "Vendor's (Seller's) Item Number"
            }
          ]
        },
        {
          "fieldId": "W0405",
          "fieldName": "Product/Service ID",
          "usage": "M",
          "minLength": 1,
          "maxLength": 48,
          "dataType": "AN",
          "fieldDescription": "Identifying number for a product or service"
        }
      ],
      "nestedSegments": [
        {
          "segmentId": "G69",
          "segmentName": "Line Item Detail - Description",
          "usage": "O",
          "maxRepeat": 5,
          "purpose": "To specify a free-form description of a line item",
          "fields": [
            {
              "fieldId": "G6901",
              "fieldName": "Free-form Description",
              "usage": "M",
              "minLength": 1,
              "maxLength": 45,
              "dataType": "AN",
              "fieldDescription": "Free-form descriptive text for the line item"
            }
          ]
        },
        {
          "segmentId": "N9",
          "segmentName": "Extended Reference Information",
          "usage": "O",
          "maxRepeat": 200,
          "purpose": "To transmit identifying information as specified by the Reference Identification Qualifier",
          "fields": [
            {
              "fieldId": "N901",
              "fieldName": "Reference Identification Qualifier",
              "usage": "M",
              "minLength": 2,
              "maxLength": 3,
              "dataType": "ID",
              "fieldDescription": "Code qualifying the Reference Identification",
              "allowedValues": [
                {
                  "value": "LT",
                  "label": "Lot Number"
                }
              ]
            },
            {
              "fieldId": "N902",
              "fieldName": "Reference Identification",
              "usage": "M",
              "minLength": 1,
              "maxLength": 30,
              "dataType": "AN",
              "fieldDescription": "Reference information as defined for a particular Transaction Set"
            }
          ],
          "syntaxRules": 2
        }
      ],
      "syntaxRules": 5
    },
    {
      "segmentId": "W03",
      "segmentName": "Total Shipment Information - Warehouse",
      "usage": "M",
      "maxRepeat": 1,
      "purpose": "To specify the total shipment in terms of quantity and weight",
      "fields": [
        {
          "fieldId": "W0301",
          "fieldName": "Number of Units Shipped",
          "usage": "M",
          "minLength": 1,
          "maxLength": 10,
          "dataType": "R",
          "fieldDescription": "Numeric value of units shipped"
        },
        {
          "fieldId": "W0302",
          "fieldName": "Weight",
          "usage": "O",
          "minLength": 1,
          "maxLength": 10,
          "dataType": "R",
          "fieldDescription": "Numeric value of weight"
        },
        {
          "fieldId": "W0303",
          "fieldName": "Unit or Basis for Measurement Code",
          "usage": "O",
          "minLength": 2,
          "maxLength": 2,
          "dataType": "ID",
          "fieldDescription": "Code specifying the units",
          "allowedValues": [
            {
              "value": "BO",
              "label": "Bottle"
            },
            {
              "value": "BG",
              "label": "Bag"
            },
            {
              "value": "PA",
              "label": "Pail"
            },
            {
              "value": "PL",
              "label": "Pallet/Unit Load"
            },
            {
              "value": "SV",
              "label": "Skid"
            },
            {
              "value": "CA",
              "label": "Case"
            },
            {
              "value": "CT",
              "label": "Carton"
            },
            {
              "value": "EA",
              "label": "Each"
            },
            {
              "value": "RL",
              "label": "Roll"
            }
          ]
        }
      ],
      "syntaxRules": 3
    },
    {
      "segmentId": "SE",
      "segmentName": "Transaction Set Trailer",
      "usage": "M",
      "maxRepeat": 1,
      "purpose": "To indicate the end of the transaction set and provide the count of transmitted segments",
      "fields": [
        {
          "fieldId": "SE01",
          "fieldName": "Number of Included Segments",
          "usage": "M",
          "minLength": 1,
          "maxLength": 10,
          "dataType": "N0",
          "fieldDescription": "Total number of segments including ST and SE segments"
        },
        {
          "fieldId": "SE02",
          "fieldName": "Transaction Set Control Number",
          "usage": "M",
          "minLength": 4,
          "maxLength": 9,
          "dataType": "AN",
          "fieldDescription": "Transaction set control number (must match ST02)"
        }
      ]
    },
    {
      "segmentId": "GE",
      "segmentName": "Functional Group Trailer",
      "usage": "M",
      "maxRepeat": 1,
      "purpose": "To indicate the end of a functional group and provide control information",
      "fields": [
        {
          "fieldId": "GE01",
          "fieldName": "Number of Transaction Sets Included",
          "usage": "M",
          "minLength": 1,
          "maxLength": 6,
          "dataType": "N0",
          "fieldDescription": "Total number of transaction sets included in the functional group or interchange"
        },
        {
          "fieldId": "GE02",
          "fieldName": "Group Control Number",
          "usage": "M",
          "minLength": 1,
          "maxLength": 9,
          "dataType": "N0",
          "fieldDescription": "Assigned number originated and maintained by the sender (must match GS06)"
        }
      ]
    },
    {
      "segmentId": "IEA",
      "segmentName": "Interchange Control Trailer",
      "usage": "M",
      "maxRepeat": 1,
      "purpose": "To define the end of an interchange of zero or more functional groups and interchange-related control segments",
      "fields": [
        {
          "fieldId": "IEA01",
          "fieldName": "Number of Included Functional Groups",
          "usage": "M",
          "minLength": 1,
          "maxLength": 5,
          "dataType": "N0",
          "fieldDescription": "A count of the number of functional groups included in an interchange"
        },
        {
          "fieldId": "IEA02",
          "fieldName": "Interchange Control Number",
          "usage": "M",
          "minLength": 9,
          "maxLength": 9,
          "dataType": "N0",
          "fieldDescription": "A control number assigned by the interchange sender (must match ISA13)"
        }
      ]
    }
  ]
}
